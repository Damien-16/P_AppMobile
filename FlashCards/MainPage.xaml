<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FlashCards.MainPage"
             BackgroundColor="#F0F4F8">

    <VerticalStackLayout
        Padding="30"
        Spacing="30"
        VerticalOptions="Center">

        <Label
            Text="Bienvenu sur&#10;Ozzlet"
            TextColor="#5E61E6"
            FontSize="28"
            FontAttributes="Bold"
            HorizontalTextAlignment="Center"
            Margin="0,0,0,40" />

        <Button
            Text="Apprendre"
            BackgroundColor="#5E61E6"
            TextColor="White"
            HeightRequest="60"
            CornerRadius="15"
            FontSize="20"
            CharacterSpacing="1"
            Clicked="OnLearnClicked" />

        <Button
            Text="Gerer mes cartes"
            BackgroundColor="Transparent"
            TextColor="#5E61E6"
            BorderColor="#5E61E6"
            BorderWidth="1"
            HeightRequest="60"
            CornerRadius="15"
            FontSize="20"
            Clicked="OnManageDecksClicked" />

    </VerticalStackLayout>

</ContentPage>