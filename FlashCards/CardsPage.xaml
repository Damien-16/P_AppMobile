<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FlashCards.CardsPage"
             Title="Cartes du Deck">

    <Grid RowDefinitions="Auto,*,Auto" Padding="10">
        
        <VerticalStackLayout Grid.Row="0" Spacing="10" Margin="0,0,0,10">
            <Entry x:Name="FrontEntry" Placeholder="Recto (Question)" />
            <Entry x:Name="BackEntry" Placeholder="Verso (Réponse)" />
            <Button Text="Ajouter la carte" Clicked="OnAddCardClicked" BackgroundColor="#2196F3" />
            <Button Text="Apprendre ce Deck" Clicked="OnStudyClicked" BackgroundColor="#4CAF50" />
        </VerticalStackLayout>

        <CollectionView Grid.Row="1" x:Name="CardsCollectionView">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0,5" Padding="10">
                        <Grid ColumnDefinitions="*,*,Auto">
                            <Label Grid.Column="0" Text="{Binding Front}" VerticalOptions="Center" FontAttributes="Bold" />
                            <Label Grid.Column="1" Text="{Binding Back}" VerticalOptions="Center" TextColor="Gray" />
                            <Button Grid.Column="2" Text="🗑️" Clicked="OnDeleteCardClicked" 
                                    CommandParameter="{Binding .}" BackgroundColor="Transparent" />
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Grid.Row="2" Text="Retour" Clicked="OnBackClicked" Margin="0,10,0,0" BackgroundColor="Gray" />
    </Grid>
</ContentPage>