<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="P_AppMobile_ReadMe.DetailPage"
             Title="Lecture">

    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="15">
            <Image 
                Source="{Binding SelectedBook.CoverImagePath}"
                HeightRequest="300"
                Aspect="AspectFit"
                HorizontalOptions="Center" />

            <Label 
                Text="{Binding SelectedBook.Title}"
                FontSize="24"
                FontAttributes="Bold"
                HorizontalOptions="Center"
                HorizontalTextAlignment="Center" />

            <BoxView HeightRequest="1" Color="LightGray" Margin="0,5,0,10" />

            <Label 
                x:Name="BookContentLabel"
                Text="Chargement du texte..."
                FontSize="16"
                LineBreakMode="WordWrap" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>