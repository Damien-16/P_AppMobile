<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="P_AppMobile_ReadMe.MainPage"
             BackgroundColor="White">

    <Grid RowDefinitions="Auto,*,Auto">
        <VerticalStackLayout Grid.Row="0" Padding="20,15,20,5" Spacing="5">
            <Label Text="Tous les livres" FontSize="22" FontAttributes="Bold" TextColor="Black" />
            <BoxView HeightRequest="1" Color="#D3D3D3" HorizontalOptions="Fill" />
        </VerticalStackLayout>

        <CollectionView Grid.Row="1" ItemsSource="{Binding Books}" SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame CornerRadius="10" BorderColor="#D3D3D3" Padding="10" Margin="15,5" BackgroundColor="White" HasShadow="False">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="15">

                            <Grid Grid.Column="0" WidthRequest="60" HeightRequest="60">
                                <BoxView Color="#512BD4" CornerRadius="5" />
                                <Image Source="{Binding CoverImagePath}" Aspect="AspectFill" Margin="0" />
                            </Grid>

                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                <Label Text="{Binding Title}" FontSize="18" TextColor="Black" FontAttributes="Bold" MaxLines="1" LineBreakMode="TailTruncation" />
                                <Label Text="{Binding DisplayDate}" FontSize="12" TextColor="Gray" />
                                <VerticalStackLayout.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnBookTapped" />
                                </VerticalStackLayout.GestureRecognizers>
                            </VerticalStackLayout>

                            <Button Grid.Column="2"
                            Text="🗑"
                            FontSize="20"
                            BackgroundColor="Transparent"
                            TextColor="Red" 
                            VerticalOptions="Center"
                            HorizontalOptions="End"
                            Clicked="OnDeleteBookClicked"
                            CommandParameter="{Binding .}" />
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Grid.Row="2" Text="Importer un livre" Clicked="OnImportClicked" Margin="20" BackgroundColor="#512BD4" TextColor="White" />
    </Grid>

</ContentPage>